# EditorConfig — https://editorconfig.org
# Editors that support it (Zed, VS Code, Cursor, etc.) apply these
# defaults unless a project has its own .editorconfig.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{diff,patch}]
trim_trailing_whitespace = false
