// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "debugger": {
    "button": false
  },
  "cli_default_open_behavior": "new_window",
  "format_on_save": "on",
  "icon_theme": "Catppuccin Macchiato",
  "collaboration_panel": {
    "button": false,
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "button": false,
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "edit_predictions": {
    "provider": "zed",
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "session": {
    "trust_all_worktrees": true,
  },
  "agent_servers": {
    "cursor": {
      "default_config_options": {
        "model": "grok-4.5",
        "mode": "agent"
      },
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
}
